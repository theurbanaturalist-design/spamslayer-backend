# ─────────────────────────────────────────────────────────────────────────────
#  SpamSlayer — Dedicated TCPA Worker
#
#  This is the standalone SpamSlayer bot with its own dedicated Twilio number.
#  All users forward their spam calls HERE. Sam answers, engages, records, and
#  builds TCPA cases. Users earn $100 per settled case.
#
#  !! Fill in your actual values and never commit this file !!
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini (conversation AI) ─────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Twilio — use your DEDICATED SpamSlayer number here ──────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Your new dedicated SpamSlayer phone number
# Set voice webhook to: https://your-url.onrender.com/api/phone/inbound
# Set SMS webhook to:   https://your-url.onrender.com/api/sms/inbound
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3003

# Your public URL (required for Twilio signature validation in production)
# e.g. https://spamslayer.onrender.com
BASE_URL=
