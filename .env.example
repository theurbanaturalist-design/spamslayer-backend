# ─────────────────────────────────────────────────────────────────────────────
#  SpamSlayer — Environment Variables
#
#  Copy this to .env and fill in your real values.
#  NEVER commit .env to git — only this .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini (AI conversation engine) ───────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Twilio (voice + SMS) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# The single SpamSlayer number — all subscribers forward spam calls here,
# and all users text this number to sign up and manage their account.
# Buy one in Twilio Console → Phone Numbers → Buy a Number
# Set its Voice webhook to: https://your-url.onrender.com/api/phone/inbound
# Set its SMS webhook to:   https://your-url.onrender.com/api/sms/inbound
TWILIO_PHONE_NUMBER=+13375551234

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3003

# Your public URL (required for Twilio signature validation in production)
# Set this to your Render URL, e.g. https://spamslayer.onrender.com
# Leave blank in local dev to skip signature validation
BASE_URL=
