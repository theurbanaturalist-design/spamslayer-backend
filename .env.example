# ─────────────────────────────────────────────────────────────────────────────
#  SpamSlayer — Environment Variables
#
#  Copy this to .env and fill in your real values.
#  NEVER commit .env to git — only this .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini (AI conversation engine) ───────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Twilio (voice + SMS) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# The single SpamSlayer number — all subscribers forward spam calls here,
# and all users text this number to sign up and manage their account.
# Buy one in Twilio Console → Phone Numbers → Buy a Number
# Set its Voice webhook to: https://your-url.onrender.com/api/phone/inbound
# Set its SMS webhook to:   https://your-url.onrender.com/api/sms/inbound
TWILIO_PHONE_NUMBER=+13375551234

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3003

# Your public URL (required for Twilio signature validation in production)
# Set this to your Render URL, e.g. https://spamslayer.onrender.com
# Leave blank in local dev to skip signature validation
BASE_URL=

# ── Supabase (Postgres + Auth) ──────────────────────────────────────────────
# Project: Spam-Slayer (vwfnmcfvaasrouiiejos)
# Dashboard: https://supabase.com/dashboard/project/vwfnmcfvaasrouiiejos
#
# SUPABASE_URL: always public (safe to ship)
# SUPABASE_ANON_KEY: public, enforces Row Level Security
# SUPABASE_SERVICE_ROLE_KEY: SECRET — bypasses RLS, backend-only, never commit
SUPABASE_URL=https://vwfnmcfvaasrouiiejos.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Feature flag: which backend does caseBuilder read from?
#   json     = use local cases.json (default, keeps current demo working)
#   supabase = use Postgres via supabaseClient.ts
CASES_BACKEND=json

# ── Discord notifications (optional) ─────────────────────────────────────────
# When set, every spam call POSTed to /api/cases/log fires a Discord embed
# with the conversation grade, extracted info, and a snippet. Newly-actionable
# cases get a second, higher-priority embed.
#
# To get a webhook URL:
#   1. In Discord, open the channel you want notifications in.
#   2. Channel name → Edit Channel → Integrations → Webhooks → New Webhook.
#   3. Name it "SpamSlayer", optionally set an avatar, click "Copy Webhook URL".
#   4. Paste below. The URL itself is the secret — don't commit it.
#
# Trial cutoff: notifications stop after this date (UTC). Defaults to one
# month after initial enable. To extend, change the date here and restart.
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_UNTIL=2026-06-02

# ── Researcher component (defendant identification + collectability) ────────
#
# Perplexity Sonar (REQUIRED for defendant web research):
#   - Powers the deep-research summary that lands in defendant_research.txt
#     when a case becomes actionable.
#   - Cost: ~$0.005-0.01 per actionable case (base "sonar" model).
#   - Get a key at https://www.perplexity.ai/api-platform
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
#   Optional: promote to "sonar-pro" for better synthesis (~3x cost).
#   For one-off pre-filing deep research, call with model="sonar-deep-research"
#   manually (~$0.41/query — gated explicitly to avoid surprise bills).
#
# CourtListener (federal litigation history — FREE public tier):
#   - Optional API key for higher rate limits. Free for non-profits and
#     personal use.
#   - Get a key at https://www.courtlistener.com/help/api/
COURTLISTENER_API_KEY=
#
# OpenCorporates (entity registry — OPTIONAL, expensive):
#   - 2026 pricing: free tier requires open-data publication (won't
#     work for a personal/legal-aid use), and the cheapest paid tier is
#     ~£190/mo (~$240/mo). NOT recommended for SpamSlayer.
#   - Sonar already covers entity identity (registered name, jurisdiction,
#     registered agent) for ~$0.005 per lookup, with broader coverage.
#   - Only set this if you genuinely need the structured entity-status
#     signal AND are okay with the price tag.
OPENCORPORATES_API_KEY=

# ── Pressure-stack auto-fire (outbound emails on your behalf) ───────────────
#
# When AUTO_SEND_PRESSURE=true AND SMTP is configured, the system will
# AUTOMATICALLY send the following on your behalf when a case becomes
# actionable:
#   - Class-action firm referral (to CLASS_ACTION_REFERRAL_EMAIL,
#     defaults to intake@lemberglaw.com)
#   - USTelecom industry escalation (info@ustelecom.org)
#   - Carrier-of-record abuse complaint (after ITG identifies the carrier;
#     auto-routed to abuse@<carrier> using a built-in lookup table)
#   - Domain registrar abuse complaint (after Sonar surfaces a defendant
#     website; routed via WHOIS lookup to abuse@<registrar>)
#
# Each outbound email BCC's your SMTP_FROM as an audit trail.
# Discord posts a "Auto-fired pressure stack" embed listing what was sent.
# Hard cap: 30 outbound sends per process per hour.
#
# WITHOUT AUTO_SEND_PRESSURE=true (the default), the system generates the
# email content and shows it on the dashboard / in the saved filing packet,
# but you have to send it manually (copy-paste the template).
AUTO_SEND_PRESSURE=false

# Gmail example (use an App Password, NOT your regular Gmail password —
# https://support.google.com/accounts/answer/185833):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxxxxxxxxxxxxxx     (16-char app password, no spaces)
#   SMTP_FROM=Marcus DeScant <you@gmail.com>
#
# SendGrid / Postmark / SES also work — any SMTP-compatible provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

# Override the default class-action firm referral recipient (defaults to
# intake@lemberglaw.com). Use a firm you've already vetted.
CLASS_ACTION_REFERRAL_EMAIL=
